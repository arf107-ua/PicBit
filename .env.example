# ── PostgreSQL (Supabase) ─────────────────────────────────────────────
# Encuéntralo en: Supabase → Settings → Database → Connection string
SUPABASE_DB_URL=jdbc:postgresql://db.TUPROYECTO.supabase.co:5432/postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=

# ── Supabase Storage ──────────────────────────────────────────────────
# Encuéntralo en: Supabase → Settings → API
SUPABASE_URL=https://TUPROYECTO.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=picflow-images

# ── MongoDB Atlas ─────────────────────────────────────────────────────
# Encuéntralo en: Atlas → Connect → Drivers
MONGO_HOST=cluster0.xxxxx.mongodb.net
MONGODB_URI=mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/imagepipeline?retryWrites=true&w=majority

# ── RabbitMQ (CloudAMQP) ──────────────────────────────────────────────
# Encuéntralo en: CloudAMQP → Details → AMQP URL
RABBITMQ_URL=amqps://usuario:password@hefty.rmq.cloudamqp.com/vhost

JWT_SECRET=